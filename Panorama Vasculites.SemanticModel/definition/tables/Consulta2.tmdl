	partition Consulta2 = m
		mode: import
		source =
				let
				    Fonte = Value.NativeQuery(GoogleBigQuery.Database(){[Name="citric-yen-471810-j7"]}[Data], "WITH #(lf)dicionario_carater_internacao AS (#(lf)    SELECT#(lf)        chave AS chave_carater_internacao,#(lf)        valor AS descricao_carater_internacao#(lf)    FROM `basedosdados.br_ms_sih.dicionario`#(lf)    WHERE#(lf)        nome_coluna = 'carater_internacao'#(lf)        AND id_tabela = 'aihs_reduzidas'#(lf)),#(lf)dicionario_sexo_paciente AS (#(lf)    SELECT#(lf)        chave AS chave_sexo_paciente,#(lf)        valor AS descricao_sexo_paciente#(lf)    FROM `basedosdados.br_ms_sih.dicionario`#(lf)    WHERE#(lf)        nome_coluna = 'sexo_paciente'#(lf)        AND id_tabela = 'aihs_reduzidas'#(lf)),#(lf)dicionario_procedimento_solicitado AS (#(lf)    SELECT#(lf)        chave AS chave_procedimento_solicitado,#(lf)        valor AS descricao_procedimento_solicitado#(lf)    FROM `basedosdados.br_ms_sih.dicionario`#(lf)    WHERE#(lf)        nome_coluna = 'procedimento_solicitado'#(lf)        AND id_tabela = 'aihs_reduzidas'#(lf)),#(lf)dicionario_procedimento_realizado AS (#(lf)    SELECT#(lf)        chave AS chave_procedimento_realizado,#(lf)        valor AS descricao_procedimento_realizado#(lf)    FROM `basedosdados.br_ms_sih.dicionario`#(lf)    WHERE#(lf)        nome_coluna = 'procedimento_realizado'#(lf)        AND id_tabela = 'aihs_reduzidas'#(lf)),#(lf)dicionario_complexidade AS (#(lf)    SELECT#(lf)        chave AS chave_complexidade,#(lf)        valor AS descricao_complexidade#(lf)    FROM `basedosdados.br_ms_sih.dicionario`#(lf)    WHERE#(lf)        nome_coluna = 'complexidade'#(lf)        AND id_tabela = 'aihs_reduzidas'#(lf))#(lf)#(lf)SELECT#(lf)    dados.ano AS ano,#(lf)    dados.mes AS mes,#(lf)#(lf)    dir_paciente.sigla_uf AS uf_paciente,#(lf)    dir_estabelecimento.sigla_uf AS uf_estabelecimento,#(lf)#(lf)    dir_paciente.nome AS municipio_paciente_nome,#(lf)    dir_estabelecimento.nome AS municipio_estabelecimento_nome,#(lf)#(lf)    dados.id_aih AS id_aih,#(lf)    descricao_carater_internacao AS carater_internacao,#(lf)    dados.data_internacao AS data_internacao,#(lf)    dados.data_saida AS data_saida,#(lf)#(lf)    dados.id_municipio_estabelecimento AS id_municipio_estabelecimento,#(lf)    dados.id_municipio_paciente AS id_municipio_paciente,#(lf)#(lf)    dados.idade_paciente AS idade_paciente,#(lf)    descricao_sexo_paciente AS sexo_paciente,#(lf)    descricao_procedimento_solicitado AS procedimento_solicitado,#(lf)    descricao_procedimento_realizado AS procedimento_realizado,#(lf)    descricao_complexidade AS complexidade,#(lf)#(lf)    dados.cid_principal_subcategoria AS cid_principal_subcategoria,#(lf)    dados.cid_secundario_subcategoria AS cid_secundario_subcategoria,#(lf)    dados.cid_diagnostico_secundario_1_subcategoria AS cid_diagnostico_secundario_1_subcategoria,#(lf)    dados.cid_diagnostico_secundario_2_subcategoria AS cid_diagnostico_secundario_2_subcategoria,#(lf)#(lf)    dados.indicador_obito AS indicador_obito,#(lf)    dados.quantidade_dias_uti_mes AS quantidade_dias_uti_mes,#(lf)    dados.quantidade_dias_unidade_intermediaria AS quantidade_dias_unidade_intermediaria,#(lf)    dados.quantidade_dias AS quantidade_dias,#(lf)    dados.valor_aih AS valor_aih,#(lf)#(lf)    CASE#(lf)        WHEN COALESCE(dados.cid_principal_subcategoria, '') = 'M300'#(lf)          OR COALESCE(dados.cid_secundario_subcategoria, '') = 'M300'#(lf)          OR COALESCE(dados.cid_diagnostico_secundario_1_subcategoria, '') = 'M300'#(lf)          OR COALESCE(dados.cid_diagnostico_secundario_2_subcategoria, '') = 'M300'#(lf)            THEN 'Poliarterite nodosa'#(lf)#(lf)        WHEN COALESCE(dados.cid_principal_subcategoria, '') = 'M301'#(lf)          OR COALESCE(dados.cid_secundario_subcategoria, '') = 'M301'#(lf)          OR COALESCE(dados.cid_diagnostico_secundario_1_subcategoria, '') = 'M301'#(lf)          OR COALESCE(dados.cid_diagnostico_secundario_2_subcategoria, '') = 'M301'#(lf)            THEN 'EGPA / Churg-Strauss'#(lf)#(lf)        WHEN COALESCE(dados.cid_principal_subcategoria, '') = 'M302'#(lf)          OR COALESCE(dados.cid_secundario_subcategoria, '') = 'M302'#(lf)          OR COALESCE(dados.cid_diagnostico_secundario_1_subcategoria, '') = 'M302'#(lf)          OR COALESCE(dados.cid_diagnostico_secundario_2_subcategoria, '') = 'M302'#(lf)            THEN 'Poliarterite juvenil'#(lf)#(lf)        WHEN COALESCE(dados.cid_principal_subcategoria, '') = 'M303'#(lf)          OR COALESCE(dados.cid_secundario_subcategoria, '') = 'M303'#(lf)          OR COALESCE(dados.cid_diagnostico_secundario_1_subcategoria, '') = 'M303'#(lf)          OR COALESCE(dados.cid_diagnostico_secundario_2_subcategoria, '') = 'M303'#(lf)            THEN 'Doença de Kawasaki'#(lf)#(lf)        WHEN COALESCE(dados.cid_principal_subcategoria, '') = 'M312'#(lf)          OR COALESCE(dados.cid_secundario_subcategoria, '') = 'M312'#(lf)          OR COALESCE(dados.cid_diagnostico_secundario_1_subcategoria, '') = 'M312'#(lf)          OR COALESCE(dados.cid_diagnostico_secundario_2_subcategoria, '') = 'M312'#(lf)            THEN 'Granulomatose com poliangiite'#(lf)#(lf)        WHEN COALESCE(dados.cid_principal_subcategoria, '') = 'M314'#(lf)          OR COALESCE(dados.cid_secundario_subcategoria, '') = 'M314'#(lf)          OR COALESCE(dados.cid_diagnostico_secundario_1_subcategoria, '') = 'M314'#(lf)          OR COALESCE(dados.cid_diagnostico_secundario_2_subcategoria, '') = 'M314'#(lf)            THEN 'Arterite de Takayasu'#(lf)#(lf)        WHEN COALESCE(dados.cid_principal_subcategoria, '') = 'M315'#(lf)          OR COALESCE(dados.cid_secundario_subcategoria, '') = 'M315'#(lf)          OR COALESCE(dados.cid_diagnostico_secundario_1_subcategoria, '') = 'M315'#(lf)          OR COALESCE(dados.cid_diagnostico_secundario_2_subcategoria, '') = 'M315'#(lf)            THEN 'Arterite de células gigantes'#(lf)#(lf)        WHEN COALESCE(dados.cid_principal_subcategoria, '') = 'M317'#(lf)          OR COALESCE(dados.cid_secundario_subcategoria, '') = 'M317'#(lf)          OR COALESCE(dados.cid_diagnostico_secundario_1_subcategoria, '') = 'M317'#(lf)          OR COALESCE(dados.cid_diagnostico_secundario_2_subcategoria, '') = 'M317'#(lf)            THEN 'Poliangiite microscópica'#(lf)#(lf)        WHEN COALESCE(dados.cid_principal_subcategoria, '') = 'M318'#(lf)          OR COALESCE(dados.cid_secundario_subcategoria, '') = 'M318'#(lf)          OR COALESCE(dados.cid_diagnostico_secundario_1_subcategoria, '') = 'M318'#(lf)          OR COALESCE(dados.cid_diagnostico_secundario_2_subcategoria, '') = 'M318'#(lf)            THEN 'Outras vasculites necrotizantes'#(lf)#(lf)        WHEN COALESCE(dados.cid_principal_subcategoria, '') = 'M319'#(lf)          OR COALESCE(dados.cid_secundario_subcategoria, '') = 'M319'#(lf)          OR COALESCE(dados.cid_diagnostico_secundario_1_subcategoria, '') = 'M319'#(lf)          OR COALESCE(dados.cid_diagnostico_secundario_2_subcategoria, '') = 'M319'#(lf)            THEN 'Vasculite necrotizante não especificada'#(lf)#(lf)        ELSE 'Outros'#(lf)    END AS tipo_vasculite#(lf)#(lf)FROM `basedosdados.br_ms_sih.aihs_reduzidas` AS dados#(lf)#(lf)LEFT JOIN `dicionario_carater_internacao`#(lf)    ON dados.carater_internacao = chave_carater_internacao#(lf)#(lf)LEFT JOIN `dicionario_sexo_paciente`#(lf)    ON dados.sexo_paciente = chave_sexo_paciente#(lf)#(lf)LEFT JOIN `dicionario_procedimento_solicitado`#(lf)    ON dados.procedimento_solicitado = chave_procedimento_solicitado#(lf)#(lf)LEFT JOIN `dicionario_procedimento_realizado`#(lf)    ON dados.procedimento_realizado = chave_procedimento_realizado#(lf)#(lf)LEFT JOIN `dicionario_complexidade`#(lf)    ON dados.complexidade = chave_complexidade#(lf)#(lf)LEFT JOIN `basedosdados.br_bd_diretorios_brasil.municipio` AS dir_paciente#(lf)    ON SUBSTR(CAST(dir_paciente.id_municipio AS STRING), 1, 6) = CAST(dados.id_municipio_paciente AS STRING)#(lf)#(lf)LEFT JOIN `basedosdados.br_bd_diretorios_brasil.municipio` AS dir_estabelecimento#(lf)    ON SUBSTR(CAST(dir_estabelecimento.id_municipio AS STRING), 1, 6) = CAST(dados.id_municipio_estabelecimento AS STRING)#(lf)#(lf)WHERE#(lf)    dados.ano BETWEEN 2023 AND 2025#(lf)    AND (#(lf)        COALESCE(dados.cid_principal_subcategoria, '') IN ('M300','M301','M302','M303','M312','M314','M315','M317','M318','M319')#(lf)        OR COALESCE(dados.cid_secundario_subcategoria, '') IN ('M300','M301','M302','M303','M312','M314','M315','M317','M318','M319')#(lf)        OR COALESCE(dados.cid_diagnostico_secundario_1_subcategoria, '') IN ('M300','M301','M302','M303','M312','M314','M315','M317','M318','M319')#(lf)        OR COALESCE(dados.cid_diagnostico_secundario_2_subcategoria, '') IN ('M300','M301','M302','M303','M312','M314','M315','M317','M318','M319')#(lf)    )", null, [EnableFolding=true])
				in
				    Fonte

	annotation PBI_ResultType = Table

